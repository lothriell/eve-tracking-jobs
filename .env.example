# EVE Online SSO Configuration
# Get these from https://developers.eveonline.com/applications
# Create a new application with the callback URL: http://10.69.10.15:9000/auth/callback
EVE_CLIENT_ID=your_eve_client_id_here
EVE_CLIENT_SECRET=your_eve_client_secret_here
EVE_REDIRECT_URI=http://10.69.10.15:9000/auth/callback

# Application Credentials
# Set your desired username and password for the web application
APP_USERNAME=admin
APP_PASSWORD=your_secure_password_here

# Session Secret
# Generate a random string for session encryption
# You can use: openssl rand -base64 32
SESSION_SECRET=your_random_session_secret_here

# Optional: Customize URLs if needed
FRONTEND_URL=http://10.69.10.15:9000
