# ============================================================================
# EVE Industry Tracker - Environment Configuration Template
# ============================================================================
# 
# Copy this file to .env and update with your actual values
# 
# Deployment Options:
#   1. Local IP Address (e.g., 192.168.1.100, 10.0.0.50)
#   2. Hostname (e.g., eve-tracker.local, eve.mydomain.com)
#   3. Tailscale IP (e.g., 100.82.8.96)
#   4. Tailscale MagicDNS (e.g., server-name.tailnet-xxxx.ts.net)
# 
# ============================================================================

# ----------------------------------------------------------------------------
# DEPLOYMENT CONFIGURATION
# ----------------------------------------------------------------------------
# Choose ONE of the following deployment options and update the URLs below
# ----------------------------------------------------------------------------

# Option 1: Local IP Address
# Use this for local network access only
# Example: http://192.168.1.100:9000
# YOUR_SERVER_ADDRESS=192.168.1.100

# Option 2: Hostname
# Use this if you have a local DNS or domain name
# Example: http://eve-tracker.local:9000
# YOUR_SERVER_ADDRESS=eve-tracker.local

# Option 3: Tailscale IP
# Use this for access via Tailscale network (recommended for remote access)
# Example: http://100.82.8.96:9000
# YOUR_SERVER_ADDRESS=100.82.8.96

# Option 4: Tailscale MagicDNS
# Use this if you have Tailscale MagicDNS enabled
# Example: http://server-name.tailnet-xxxx.ts.net:9000
# YOUR_SERVER_ADDRESS=server-name.tailnet-xxxx.ts.net

# Set your chosen server address here:
YOUR_SERVER_ADDRESS=YOUR_IP_OR_HOSTNAME

# Port (default: 9000)
PORT=9000

# ----------------------------------------------------------------------------
# EVE Online SSO Configuration
# ----------------------------------------------------------------------------
# Get these from: https://developers.eveonline.com/applications
# 
# Steps:
# 1. Go to https://developers.eveonline.com/applications
# 2. Create a new application or edit existing one
# 3. Set the callback URL to: http://YOUR_SERVER_ADDRESS:9000/auth/callback
#    (Replace YOUR_SERVER_ADDRESS with your actual address from above)
# 4. Copy the Client ID and Secret below
# 
# Required Scopes:
#   - esi-industry.read_character_jobs.v1
#   - esi-skills.read_skills.v1
#   - esi-industry.read_corporation_jobs.v1
#   - esi-corporations.read_corporation_membership.v1
#   - esi-characters.read_corporation_roles.v1
# ----------------------------------------------------------------------------

EVE_CLIENT_ID=YOUR_EVE_CLIENT_ID
EVE_CLIENT_SECRET=YOUR_EVE_CLIENT_SECRET
EVE_REDIRECT_URI=http://YOUR_SERVER_ADDRESS:9000/auth/callback

# ----------------------------------------------------------------------------
# Application Credentials
# ----------------------------------------------------------------------------
# Set your desired username and password for the web application
# These are used to log into the web interface (not EVE SSO)
# ----------------------------------------------------------------------------

APP_USERNAME=YOUR_USERNAME
APP_PASSWORD=YOUR_PASSWORD

# ----------------------------------------------------------------------------
# Session Security
# ----------------------------------------------------------------------------
# Generate a random string for session encryption
# 
# Generate using one of these methods:
#   - Linux/Mac: openssl rand -base64 32
#   - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   - Online: https://www.random.org/strings/
# 
# Keep this secret and never share it!
# ----------------------------------------------------------------------------

SESSION_SECRET=YOUR_RANDOM_SESSION_SECRET

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
# These are automatically set based on YOUR_SERVER_ADDRESS above
# You can override them if needed
# ----------------------------------------------------------------------------

FRONTEND_URL=http://YOUR_SERVER_ADDRESS:9000
SERVER_IP=YOUR_SERVER_ADDRESS

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------

PROJECT_NAME=eve_esi_app
NODE_ENV=production

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Allow access from your server address
# Add multiple origins separated by commas if needed
# Example: http://192.168.1.100:9000,http://100.82.8.96:9000
# ----------------------------------------------------------------------------

ALLOWED_ORIGINS=http://YOUR_SERVER_ADDRESS:9000

# ============================================================================
# DEPLOYMENT EXAMPLES
# ============================================================================

# Example 1: Local IP Address (192.168.1.100)
# --------------------------------------------
# YOUR_SERVER_ADDRESS=192.168.1.100
# PORT=9000
# EVE_CLIENT_ID=abc123...
# EVE_CLIENT_SECRET=xyz789...
# EVE_REDIRECT_URI=http://192.168.1.100:9000/auth/callback
# APP_USERNAME=admin
# APP_PASSWORD=secure_password_here
# SESSION_SECRET=random_32_byte_base64_string
# FRONTEND_URL=http://192.168.1.100:9000
# SERVER_IP=192.168.1.100
# ALLOWED_ORIGINS=http://192.168.1.100:9000

# Example 2: Tailscale IP (100.82.8.96)
# --------------------------------------
# YOUR_SERVER_ADDRESS=100.82.8.96
# PORT=9000
# EVE_CLIENT_ID=abc123...
# EVE_CLIENT_SECRET=xyz789...
# EVE_REDIRECT_URI=http://100.82.8.96:9000/auth/callback
# APP_USERNAME=admin
# APP_PASSWORD=secure_password_here
# SESSION_SECRET=random_32_byte_base64_string
# FRONTEND_URL=http://100.82.8.96:9000
# SERVER_IP=100.82.8.96
# ALLOWED_ORIGINS=http://100.82.8.96:9000

# Example 3: Hostname (eve-tracker.local)
# ----------------------------------------
# YOUR_SERVER_ADDRESS=eve-tracker.local
# PORT=9000
# EVE_CLIENT_ID=abc123...
# EVE_CLIENT_SECRET=xyz789...
# EVE_REDIRECT_URI=http://eve-tracker.local:9000/auth/callback
# APP_USERNAME=admin
# APP_PASSWORD=secure_password_here
# SESSION_SECRET=random_32_byte_base64_string
# FRONTEND_URL=http://eve-tracker.local:9000
# SERVER_IP=eve-tracker.local
# ALLOWED_ORIGINS=http://eve-tracker.local:9000

# Example 4: Tailscale MagicDNS (server.tailnet-abc.ts.net)
# ----------------------------------------------------------
# YOUR_SERVER_ADDRESS=server.tailnet-abc.ts.net
# PORT=9000
# EVE_CLIENT_ID=abc123...
# EVE_CLIENT_SECRET=xyz789...
# EVE_REDIRECT_URI=http://server.tailnet-abc.ts.net:9000/auth/callback
# APP_USERNAME=admin
# APP_PASSWORD=secure_password_here
# SESSION_SECRET=random_32_byte_base64_string
# FRONTEND_URL=http://server.tailnet-abc.ts.net:9000
# SERVER_IP=server.tailnet-abc.ts.net
# ALLOWED_ORIGINS=http://server.tailnet-abc.ts.net:9000

# ============================================================================
# QUICK START GUIDE
# ============================================================================
# 
# 1. Copy this file:
#    cp .env.example .env
# 
# 2. Choose your deployment type and set YOUR_SERVER_ADDRESS
#    - Local IP: YOUR_SERVER_ADDRESS=192.168.1.100
#    - Tailscale: YOUR_SERVER_ADDRESS=100.82.8.96
#    - Hostname: YOUR_SERVER_ADDRESS=eve-tracker.local
# 
# 3. Create EVE Developer Application:
#    - Go to: https://developers.eveonline.com/applications
#    - Create new application
#    - Set callback: http://YOUR_SERVER_ADDRESS:9000/auth/callback
#    - Copy Client ID and Secret to EVE_CLIENT_ID and EVE_CLIENT_SECRET
# 
# 4. Set application credentials:
#    - APP_USERNAME: Your desired username
#    - APP_PASSWORD: Your desired password
# 
# 5. Generate session secret:
#    openssl rand -base64 32
#    Copy output to SESSION_SECRET
# 
# 6. Update all instances of YOUR_SERVER_ADDRESS in the file
# 
# 7. Save and deploy:
#    docker-compose up -d --build
# 
# 8. Access your application:
#    http://YOUR_SERVER_ADDRESS:9000
# 
# ============================================================================
