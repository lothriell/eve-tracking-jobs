# =============================================================================
# EVE ESI Application Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration (for multi-instance deployment)
# -----------------------------------------------------------------------------
# PORT: The external port the application will be accessible on
# Change this for each instance to avoid port conflicts
# Example: User 1 = 9000, User 2 = 9001, User 3 = 9002, etc.
PORT=9000

# SERVER_IP: The IP address or hostname of your server
# Used for constructing callback URLs and frontend access
SERVER_IP=10.69.10.15

# PROJECT_NAME: Unique name for Docker containers (optional)
# Use different names for multiple instances on the same server
# Example: eve-esi-user1, eve-esi-user2, etc.
PROJECT_NAME=eve-esi-app

# -----------------------------------------------------------------------------
# EVE Online SSO Configuration
# -----------------------------------------------------------------------------
# Get these from https://developers.eveonline.com/applications
# Create a new application with the callback URL matching your PORT:
# Example: http://10.69.10.15:9000/auth/callback
#
# Required ESI Scopes:
# - esi-industry.read_character_jobs.v1
# - esi-skills.read_skills.v1
# - esi-industry.read_corporation_jobs.v1
# - esi-corporations.read_corporation_membership.v1
# - esi-characters.read_corporation_roles.v1
EVE_CLIENT_ID=your_eve_client_id_here
EVE_CLIENT_SECRET=your_eve_client_secret_here
EVE_REDIRECT_URI=http://10.69.10.15:9000/auth/callback

# -----------------------------------------------------------------------------
# Application Credentials
# -----------------------------------------------------------------------------
# Set your desired username and password for the web application login
APP_USERNAME=admin
APP_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# Session Secret
# -----------------------------------------------------------------------------
# Generate a random string for session encryption
# You can use: openssl rand -base64 32
SESSION_SECRET=your_random_session_secret_here

# -----------------------------------------------------------------------------
# Optional: Customize URLs if needed
# -----------------------------------------------------------------------------
# These are auto-generated from SERVER_IP and PORT if not specified
# FRONTEND_URL=http://10.69.10.15:9000
