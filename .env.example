# =============================================================================
# EVE Industry Tracker - Environment Configuration
# =============================================================================
#
# QUICK START:
#   1. Copy this file to .env: cp .env.example .env
#   2. Replace YOUR_SERVER_ADDRESS with your actual IP or hostname
#   3. Set your EVE Developer Application credentials
#   4. Generate a session secret: openssl rand -base64 32
#   5. Run: docker-compose up -d --build
#
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# YOUR_SERVER_ADDRESS: Replace with your actual server IP or hostname
#
# Examples:
#   - Local IP:         192.168.1.100
#   - Tailscale IP:     100.82.8.96
#   - Hostname:         eve-tracker.local
#   - Tailscale DNS:    server.tailnet-abc.ts.net
#
# This address is used throughout the application for:
#   - EVE SSO callback URL
#   - Frontend URL
#   - CORS configuration

# Port the application runs on (default: 9000)
PORT=9000

# Server IP or hostname (REQUIRED - replace YOUR_SERVER_ADDRESS)
SERVER_IP=YOUR_SERVER_ADDRESS

# Project name for Docker containers (useful for multiple instances)
PROJECT_NAME=eve-esi-app

# -----------------------------------------------------------------------------
# EVE ONLINE SSO CONFIGURATION
# -----------------------------------------------------------------------------
# Get these from https://developers.eveonline.com/applications
#
# 1. Create a new application at EVE Developer Console
# 2. Set callback URL to: http://YOUR_SERVER_ADDRESS:9000/auth/callback
# 3. Enable these ESI scopes:
#    - esi-industry.read_character_jobs.v1
#    - esi-skills.read_skills.v1
#    - esi-industry.read_corporation_jobs.v1
#    - esi-corporations.read_corporation_membership.v1
#    - esi-characters.read_corporation_roles.v1
#    - esi-assets.read_assets.v1               (personal asset inventory)
#    - esi-assets.read_corporation_assets.v1   (corporation asset inventory)
#    - esi-planets.manage_planets.v1           (planetary industry colonies)
#    - esi-universe.read_structures.v1         (player structure names)
# 4. Copy Client ID and Secret Key here

EVE_CLIENT_ID=your_eve_client_id_here
EVE_CLIENT_SECRET=your_eve_client_secret_here
EVE_REDIRECT_URI=http://YOUR_SERVER_ADDRESS:9000/auth/callback

# -----------------------------------------------------------------------------
# APPLICATION CREDENTIALS
# -----------------------------------------------------------------------------
# These are YOUR login credentials for the web application
# Choose any username and password you want

APP_USERNAME=admin
APP_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# SESSION SECRET
# -----------------------------------------------------------------------------
# Generate a random string for session encryption:
#   openssl rand -base64 32
# 
# This keeps your sessions secure - use a unique random string!

SESSION_SECRET=your_random_session_secret_here

# -----------------------------------------------------------------------------
# FRONTEND URL (auto-constructed from SERVER_IP and PORT)
# -----------------------------------------------------------------------------
# Usually you don't need to change this - it's derived from above values

FRONTEND_URL=http://YOUR_SERVER_ADDRESS:9000

# =============================================================================
# DEPLOYMENT EXAMPLES
# =============================================================================
#
# EXAMPLE 1: Local Network (IP: 192.168.1.100)
# ---------------------------------------------
#   SERVER_IP=192.168.1.100
#   EVE_REDIRECT_URI=http://192.168.1.100:9000/auth/callback
#   FRONTEND_URL=http://192.168.1.100:9000
#
# EXAMPLE 2: Tailscale (IP: 100.82.8.96)
# ---------------------------------------------
#   SERVER_IP=100.82.8.96
#   EVE_REDIRECT_URI=http://100.82.8.96:9000/auth/callback
#   FRONTEND_URL=http://100.82.8.96:9000
#
# EXAMPLE 3: Hostname (eve-tracker.local)
# ---------------------------------------------
#   SERVER_IP=eve-tracker.local
#   EVE_REDIRECT_URI=http://eve-tracker.local:9000/auth/callback
#   FRONTEND_URL=http://eve-tracker.local:9000
#
# EXAMPLE 4: Tailscale MagicDNS (server.tailnet-abc.ts.net)
# ---------------------------------------------
#   SERVER_IP=server.tailnet-abc.ts.net
#   EVE_REDIRECT_URI=http://server.tailnet-abc.ts.net:9000/auth/callback
#   FRONTEND_URL=http://server.tailnet-abc.ts.net:9000
#
# =============================================================================
